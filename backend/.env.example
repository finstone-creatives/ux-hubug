# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/uxhub

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# MTN Mobile Money
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_COLLECTION_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user
MTN_API_KEY=your_mtn_api_key
MTN_ENVIRONMENT=sandbox

# Airtel Money
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_ENVIRONMENT=sandbox

# Premium Subscription Price (USD)
PREMIUM_PRICE_USD=9.99
PREMIUM_PRICE_UGX=37000

# File Upload
MAX_FILE_SIZE=500000000
UPLOAD_PATH=./uploads
FRONTEND_URL=http://localhost:3000
